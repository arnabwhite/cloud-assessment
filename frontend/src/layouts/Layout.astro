---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>AuraMatch - Celestial Harmony</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,400&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
	</head>
	<body class="relative min-h-screen bg-[#FDFBF7] font-['Lora'] text-[#4A3B32] flex flex-col antialiased selection:bg-[#E8A598] selection:text-white overflow-x-hidden">
		
		<!-- Natural, organic flowing background -->
		<div class="fixed inset-0 z-[-1] overflow-hidden pointer-events-none">
			<!-- Soft warm gradients -->
			<div class="absolute -top-[20%] -left-[10%] w-[70vw] h-[70vw] rounded-[100%] bg-gradient-to-br from-[#FFF0E6] to-[#FFE4E1] opacity-70 blur-[120px] mix-blend-multiply"></div>
			<div class="absolute top-[40%] -right-[20%] w-[80vw] h-[80vw] rounded-[100%] bg-gradient-to-tl from-[#F4E3E8] to-[#FCF4F6] opacity-60 blur-[150px] mix-blend-multiply"></div>
			<div class="absolute -bottom-[30%] left-[10%] w-[60vw] h-[60vw] rounded-[100%] bg-gradient-to-tr from-[#FFF3E8] to-[#FAEAEA] opacity-80 blur-[100px] mix-blend-multiply"></div>
			
			<!-- Paper/Canvas subtle texture -->
			<div class="absolute inset-0 opacity-[0.4]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E'); mix-blend-mode: overlay;"></div>
		</div>

		<main class="flex-grow flex items-center justify-center px-4 py-12 md:py-16 z-10">
			<slot />
		</main>
		
		<footer class="text-center pb-8 pt-4 text-[13px] text-[#A69992] z-10 font-light tracking-widest uppercase">
			&copy; 2026 AuraMatch
		</footer>
	</body>
</html>
